#!/bin/bash
# Pre-push hook: Run database tests if schema/test files changed

# Parse stdin to get local and remote SHAs
while read local_ref local_sha remote_ref remote_sha; do
  # For new branches (remote_sha = 0000...), compare to origin/main
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    compare_to="origin/main"
  else
    compare_to="$remote_sha"
  fi

  # Check if any files in supabase/migrations or supabase/tests changed
  if git diff "$compare_to".."$local_sha" --name-only --diff-filter=ACMR | \
       grep -qE '^supabase/(migrations|tests)/'; then
    echo "🔍 Schema or test files changed. Running database tests..."
    # Failure-only output: suppress pgTAP's per-test "ok" lines on success,
    # dump the full log only when something fails.
    db_out=$(npx --no-install supabase test db 2>&1)
    db_code=$?
    if [ "$db_code" -ne 0 ]; then
      printf '%s\n' "$db_out"
      exit "$db_code"
    fi
    echo "✓ Database tests passed."
    exit 0
  fi
done

exit 0
