npx lint-staged

# Run database tests when schema/test files are staged. Pre-commit (not
# pre-push) so the failure lands while an agent/author is still in-session and
# can fix it, instead of after the commit during push.
if git diff --cached --name-only --diff-filter=ACMR | \
     grep -qE '^supabase/(migrations|tests)/'; then
  echo "🔍 Schema or test files staged. Running database tests..."
  # Failure-only output: suppress pgTAP's per-test "ok" lines on success,
  # dump the full log only when something fails.
  db_out=$(npx --no-install supabase test db 2>&1)
  db_code=$?
  if [ "$db_code" -ne 0 ]; then
    printf '%s\n' "$db_out"
    exit "$db_code"
  fi
  echo "✓ Database tests passed."
fi
