{
  "exclude": ["**/*.test.ts"],
  "compilerOptions": {
    "lib": ["deno.window"],
    "target": "ES2022",
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "lint": {
    "include": ["**/*.ts"],
    "exclude": ["**/*.test.ts"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "include": ["**/*.ts"],
    "exclude": ["**/*.test.ts"],
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "always"
  }
}
